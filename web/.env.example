# Layer2 Meta Insights — Local Development Configuration
# Copy this file to .env.local and fill in your values.

# Databricks workspace hostname (without https://)
DATABRICKS_HOST=adb-1234567890.12.azuredatabricks.net

# Personal Access Token (PAT) from Databricks User Settings
DATABRICKS_TOKEN=dapi_your_token_here

# SQL Warehouse ID (from SQL Warehouses page in Databricks)
DATABRICKS_WAREHOUSE_ID=abc123def456

# Catalog and schema where Latero meta tables live
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=meta

# Optional: hard-scope live reads to one Latero environment value.
# Recommended when meta tables contain both demo and live data.
DATABRICKS_ENVIRONMENT=dev-free

# Authentication
# API key for protecting /api/* routes. Generate a random string.
INSIGHTS_API_KEY=your-random-api-key-here

# Set to "true" to disable auth during local development
INSIGHTS_AUTH_DISABLED=true

# Cache settings
# TTL in seconds (default: 86400 = 24 hours)
INSIGHTS_CACHE_TTL=86400

# Set to "true" to run without Databricks (serve only cached data)
# Use /api/cache/refresh to populate cache first while Databricks is running
INSIGHTS_CACHE_ONLY=false

# Databricks -> Postgres auto-sync (for live SaaS read store freshness)
# Set to "false" to disable periodic sync triggers on read traffic.
INSIGHTS_AUTO_SYNC_ENABLED=true
# Run at most once per interval (minutes)
INSIGHTS_AUTO_SYNC_INTERVAL_MINUTES=15
# Each run syncs this rolling date window (days)
INSIGHTS_AUTO_SYNC_WINDOW_DAYS=7

# Admin token for the key management API (POST/GET/DELETE /api/v1/installations).
# Generate a secure random string. Never use the same value as INSIGHTS_API_KEY.
# Example: openssl rand -base64 32
INSIGHTS_ADMIN_TOKEN=your-admin-token-here

# Optional: local infrastructure defaults for Azure-parity development.
# These are not required by the current runtime yet, but they keep local and
# cloud configuration aligned when moving to Postgres/queue/blob-backed state.
POSTGRES_URL=postgresql://insights:insights@localhost:5432/insights
REDIS_URL=redis://localhost:6379

# Azurite (local Azure Storage emulator)
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_STORAGE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
AZURE_STORAGE_QUEUE_ENDPOINT=http://127.0.0.1:10001/devstoreaccount1
