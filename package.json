{
  "name": "latero-insights-repo",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "start": "npm run start --workspace web",
    "lint": "npm run lint --workspace web",
    "seed": "npm run seed --workspace web",
    "infra:up": "docker compose -f infra/docker/docker-compose.local.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.local.yml down",
    "infra:reset-db": "docker compose -f infra/docker/docker-compose.local.yml down -v && docker compose -f infra/docker/docker-compose.local.yml up -d",
    "infra:logs": "docker compose -f infra/docker/docker-compose.local.yml logs -f",
    "dev:docker:up": "docker compose -f infra/docker/docker-compose.local.yml -f infra/docker/docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f infra/docker/docker-compose.local.yml -f infra/docker/docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f infra/docker/docker-compose.local.yml -f infra/docker/docker-compose.dev.yml logs -f app"
  }
}
