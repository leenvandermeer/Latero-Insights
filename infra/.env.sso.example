# SSO test environment — voorbeeld .env.local voor lokale Keycloak stack
#
# Kopieer dit bestand naar web/.env.local en pas aan voor jouw setup.
# Gebruik NOOIT deze waarden in productie.
#
# Vereiste stappen:
#   1. npm run sso:up
#   2. Wacht tot Keycloak klaar is (zie: npm run sso:logs)
#   3. Maak een installatie aan via de admin UI en stel de auth-config in:
#      - Issuer:           https://idp.latero.local/realms/latero-test
#        (of HTTP voor directe toegang: http://localhost:8080/realms/latero-test)
#      - Client ID:        latero-control
#      - Client secret ref: OIDC_CLIENT_SECRET
#      - Redirect URI:     https://app.latero.local/api/auth/sso/callback
#      - Scopes:           openid email profile
#      - PKCE:             enabled (S256)
#      - Allowed domains:  latero.nl
#      - Role mapping:     { "latero-admins": "admin", "latero-users": "member" }
#      - Auth mode:        sso_with_local_fallback (voor dev)
#      - JIT provisioning: enabled, default role: member

# OIDC state-signing secret — minimaal 32 tekens
# Genereer een eigen waarde: openssl rand -base64 32
OIDC_STATE_SECRET=sso-test-local-secret-DO-NOT-USE-IN-PRODUCTION-32x

# Keycloak client secret (staat in infra/keycloak/realm-latero-test.json)
OIDC_CLIENT_SECRET=latero-dev-secret

# Postgres (lokale infra stack)
POSTGRES_URL=postgresql://insights:insights@localhost:5432/insights
