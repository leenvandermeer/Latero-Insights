# infra/.env.prod.example
# Kopieer naar infra/.env.prod en vul alle waarden in vóór deployment.
# Dit bestand NOOIT committen met echte waarden.
#
# Genereer willekeurige secrets met:
#   openssl rand -base64 32
#
# Na 'docker compose up', voer éénmalig het bootstrap-script uit:
#   source infra/.env.prod
#   bash infra/scripts/bootstrap.sh

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# Wachtwoord voor de Keycloak-database gebruiker
KC_DB_PASSWORD=

# ── Keycloak admin ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── OIDC / SSO ────────────────────────────────────────────────────────────────
# State-signing secret — minimaal 32 tekens willekeurig
OIDC_STATE_SECRET=

# Client secret uit Keycloak (Clients → latero-control → Credentials)
OIDC_CLIENT_SECRET=

# ── Bootstrap (gebruikt door infra/scripts/bootstrap.sh) ─────────────────────
# Eerste admin-gebruiker
ADMIN_EMAIL=admin@jouwdomein.nl
ADMIN_PASSWORD=

# Installatie
INSTALLATION_ID=prod_
INSTALLATION_LABEL=Productie
INSTALLATION_ENV=prod
INSTALLATION_TOKEN=

# SSO
SSO_DOMAIN=jouwdomein.nl
SSO_ISSUER=https://sso.jouwdomein.nl/realms/latero
SSO_CLIENT_ID=latero-control
SSO_REDIRECT_URI=https://control.jouwdomein.nl/api/auth/sso/callback

# Publieke URL van de applicatie
PUBLIC_URL=https://control.jouwdomein.nl
