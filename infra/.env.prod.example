# infra/.env.prod.example
# Kopieer naar infra/.env.prod en vul alle waarden in vóór deployment.
# Dit bestand NOOIT committen met echte waarden.
#
# Genereer willekeurige secrets met:
#   openssl rand -base64 32

# ── Postgres ──────────────────────────────────────────────────────────────────
# Hoofddatabase wachtwoord (gebruikt door de insights app)
POSTGRES_PASSWORD=

# Wachtwoord voor de Keycloak-database gebruiker
KEYCLOAK_DB_PASSWORD=

# ── Keycloak admin ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── OIDC / SSO ────────────────────────────────────────────────────────────────
# State-signing secret — minimaal 32 tekens willekeurig
# Genereer: openssl rand -base64 32
OIDC_STATE_SECRET=

# Client secret — moet overeenkomen met realm-latero-prod.json (veld "secret")
# Genereer: openssl rand -base64 32
# Stel ook in in realm-latero-prod.json vóór import!
OIDC_CLIENT_SECRET=

# ── Applicatie ────────────────────────────────────────────────────────────────
# Next.js vereist een NEXTAUTH_SECRET equivalent voor sessie-encryptie (indien gebruikt)
# Genereer: openssl rand -base64 32
# AUTH_SECRET=
