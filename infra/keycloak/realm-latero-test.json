{
  "realm": "latero-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "latero-control",
      "name": "Latero Control (local dev)",
      "description": "OIDC client for local SSO testing — dev only, not for production",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "latero-dev-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/sso/callback",
        "http://localhost:3010/api/auth/sso/callback",
        "https://app.latero.local/api/auth/sso/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3010",
        "https://app.latero.local"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "groups": [
    {
      "name": "latero-users",
      "path": "/latero-users",
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {},
      "subGroups": []
    },
    {
      "name": "latero-admins",
      "path": "/latero-admins",
      "attributes": {},
      "realmRoles": [],
      "clientRoles": {},
      "subGroups": []
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@acme.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Acme",
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": false
        }
      ],
      "groups": ["/latero-users"]
    },
    {
      "username": "bob",
      "email": "bob@acme.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Bob",
      "lastName": "Acme",
      "credentials": [
        {
          "type": "password",
          "value": "Test1234!",
          "temporary": false
        }
      ],
      "groups": ["/latero-admins"]
    }
  ]
}
